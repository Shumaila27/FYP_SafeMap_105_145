//---------------------
-- ============================================================
--  SafeMap – Supabase Schema  (Production-Grade v2)
--  Run this in Supabase → SQL Editor
--
--  Changes from v1 (per Senior Architect review):
--  ✅ Phone E.164 CHECK constraint on emergency_contacts
--  ✅ Index on emergency_contacts(user_id)
--  ✅ Index on user_achievements(user_id)
--  ✅ version column on user_settings (for future migrations)
--  ✅ evaluate_achievements now fires automatically via DB trigger
--     — Flutter code no longer needs to call it manually
--  ✅ GuardianService queries no longer filter by user_id manually
--     — RLS handles scoping automatically
-- ============================================================


-- ── 1. PROFILES ─────────────────────────────────────────────
CREATE TABLE IF NOT EXISTS public.profiles (
  id          UUID        PRIMARY KEY REFERENCES auth.users(id) ON DELETE CASCADE,
  name        TEXT        NOT NULL DEFAULT '',
  email       TEXT        NOT NULL DEFAULT '',
  avatar_url  TEXT,
  is_verified BOOLEAN     NOT NULL DEFAULT FALSE,
  is_guardian BOOLEAN     NOT NULL DEFAULT FALSE,
  created_at  TIMESTAMPTZ NOT NULL DEFAULT NOW(),
  updated_at  TIMESTAMPTZ NOT NULL DEFAULT NOW()
);


-- ── 2. USER STATS ────────────────────────────────────────────
CREATE TABLE IF NOT EXISTS public.user_stats (
  user_id       UUID        PRIMARY KEY REFERENCES public.profiles(id) ON DELETE CASCADE,
  safe_walks    INTEGER     NOT NULL DEFAULT 0,
  reports       INTEGER     NOT NULL DEFAULT 0,
  safety_points INTEGER     NOT NULL DEFAULT 0,
  updated_at    TIMESTAMPTZ NOT NULL DEFAULT NOW()
);


-- ── 3. EMERGENCY CONTACTS ────────────────────────────────────
CREATE TABLE IF NOT EXISTS public.emergency_contacts (
  id         UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
  user_id    UUID        NOT NULL REFERENCES public.profiles(id) ON DELETE CASCADE,
  name       TEXT        NOT NULL CHECK (char_length(trim(name)) > 0),
  phone      TEXT        NOT NULL,
  relation   TEXT        NOT NULL DEFAULT '',
  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),

  -- ✅ FIX 1: Phone validation – accepts +923001234567 or 03001234567
  --    Allows optional leading +, then 10-15 digits only.
  --    Bad data from any client (mobile, web, API) is rejected at DB level.
  CONSTRAINT phone_format CHECK (phone ~ '^\+?[0-9]{10,15}$')
);

-- ✅ FIX 2: Index so fetching a user's contacts is O(log n) not O(n)
--    Without this, Postgres scans every row in the table for every user.
CREATE INDEX IF NOT EXISTS idx_emergency_contacts_user_id
  ON public.emergency_contacts(user_id);


-- ── 4. USER SETTINGS ─────────────────────────────────────────
CREATE TABLE IF NOT EXISTS public.user_settings (
  user_id              UUID        PRIMARY KEY REFERENCES public.profiles(id) ON DELETE CASCADE,
  -- Privacy
  anonymous_reporting  BOOLEAN     NOT NULL DEFAULT TRUE,
  location_services    BOOLEAN     NOT NULL DEFAULT TRUE,
  voice_commands       BOOLEAN     NOT NULL DEFAULT TRUE,
  -- Notifications
  safety_alerts        BOOLEAN     NOT NULL DEFAULT TRUE,
  ai_recommendations   BOOLEAN     NOT NULL DEFAULT TRUE,
  community_updates    BOOLEAN     NOT NULL DEFAULT FALSE,
  -- ✅ FIX 3: version column – if you add/rename settings columns in a
  --    future release, bump this number and your Flutter app can detect
  --    stale settings and re-apply defaults instead of crashing.
  settings_version     INTEGER     NOT NULL DEFAULT 1,
  updated_at           TIMESTAMPTZ NOT NULL DEFAULT NOW()
);


-- ── 5. ACHIEVEMENTS (catalogue) ──────────────────────────────
CREATE TABLE IF NOT EXISTS public.achievements (
  id          UUID    PRIMARY KEY DEFAULT gen_random_uuid(),
  title       TEXT    NOT NULL,
  description TEXT    NOT NULL,
  icon        TEXT    NOT NULL DEFAULT 'award',
  min_points  INTEGER,           -- null = threshold not used
  min_walks   INTEGER,
  min_reports INTEGER
);

